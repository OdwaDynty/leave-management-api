# ─── SERVER ───────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── DATABASE ─────────────────────────────────────────
# Railway provides these automatically when you add
# a PostgreSQL plugin to your project
DATABASE_URL=postgresql://user:password@host:port/dbname

# Keep these for local development fallback
DB_HOST=localhost
DB_PORT=5432
DB_NAME=leave_management
DB_USER=postgres
DB_PASSWORD=your_password_here

# ─── JWT ──────────────────────────────────────────────
# Use a long random string — never share this
JWT_SECRET=generate_a_long_random_string_here
JWT_EXPIRES_IN=7d

# ─── APP ──────────────────────────────────────────────
# Your Vercel frontend URL after deployment
APP_URL=https://leavesync.vercel.app

# ─── EMAIL ────────────────────────────────────────────
EMAIL_FROM=podyantyi@gmail.com
EMAIL_PASSWORD=pikcgjjalghupgvx
EMAIL_FROM_NAME=LeaveSync